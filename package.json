{
  "name": "gamegulf-blog",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "astro dev",
    "build": "astro sync --force && astro build",
    "build:static": "astro sync --force && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "brief": "node scripts/extract-game-brief.mjs",
    "brief:batch": "node scripts/batch-extract.mjs",
    "pricing:sync": "node scripts/sync-price-tables.mjs",
    "fix:limits": "node scripts/auto-fix-char-limits.mjs",
    "validate:all": "node scripts/validate-article.mjs --all",
    "coverage:locales": "node scripts/report-locale-coverage.mjs",
    "backfill:playtime": "node scripts/backfill-playtime-from-briefs.mjs",
    "prebuild": "npm run pricing:sync && npm run fix:limits",
    "test": "vitest run",
    "queue:articles:dry": "node scripts/run-article-queue.mjs --seed-mc --limit 3 --dry-run",
    "queue:articles:one": "node scripts/run-article-queue.mjs --seed-mc --limit 1 --claude",
    "queue:articles": "node scripts/run-article-queue.mjs --seed-mc --limit 10 --claude --continue-on-blocked"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.1",
    "@astrojs/sitemap": "^3.3.1",
    "astro": "^5.7.10",
    "js-yaml": "^4.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "patch-package": "^8.0.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
