---
import { locales, localeLabels, blogBasePath, langTags, type BlogLocale } from '@/lib/i18n';

interface Props {
  locale: BlogLocale;
  localePaths?: Partial<Record<BlogLocale, string>>;
}

const { locale, localePaths } = Astro.props;

function getLocalePath(l: BlogLocale): string {
  return localePaths?.[l] ?? `${blogBasePath}/${l}`;
}
---

<details class="lang-selector">
  <summary class="lang-selector-trigger">
    <svg class="lang-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <circle cx="12" cy="12" r="10" />
      <path d="M2 12h20" />
      <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" />
    </svg>
    <span class="lang-current">{localeLabels[locale]}</span>
    <svg class="lang-chevron" width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  </summary>
  <ul class="lang-dropdown" role="list">
    {locales.map((l) => (
      <li>
        <a
          href={getLocalePath(l)}
          class:list={['lang-option', { active: l === locale }]}
          hreflang={langTags[l]}
          lang={langTags[l]}
        >
          {localeLabels[l]}
        </a>
      </li>
    ))}
  </ul>
</details>

<style>
  .lang-selector {
    position: relative;
  }

  .lang-selector-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 36px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--muted-strong);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 160ms ease, color 160ms ease;
    list-style: none;
    user-select: none;
  }

  .lang-selector-trigger::-webkit-details-marker {
    display: none;
  }

  .lang-selector-trigger:hover {
    border-color: var(--brand);
    color: var(--brand);
  }

  .lang-icon {
    flex-shrink: 0;
  }

  .lang-chevron {
    flex-shrink: 0;
    transition: transform 200ms ease;
  }

  .lang-selector[open] .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-dropdown {
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    z-index: 50;
    min-width: 160px;
    padding: 6px 0;
    margin: 0;
    list-style: none;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-md);
    animation: lang-dropdown-in 160ms ease;
  }

  @keyframes lang-dropdown-in {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .lang-option {
    display: block;
    padding: 8px 16px;
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--text);
    transition: background 120ms ease;
  }

  .lang-option:hover {
    background: var(--bg-alt);
  }

  .lang-option.active {
    color: var(--brand);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .lang-current {
      display: none;
    }

    .lang-chevron {
      display: none;
    }

    .lang-selector-trigger {
      padding: 0 10px;
      min-height: 34px;
    }

    .lang-dropdown {
      right: -8px;
    }
  }
</style>
