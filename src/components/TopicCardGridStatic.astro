---
import DecisionFeaturedCardStatic from './DecisionFeaturedCardStatic.astro';
import DecisionGridCardStatic from './DecisionGridCardStatic.astro';
import type { DecisionEntryCardModel } from '@/lib/blog-shared';
import type { BlogLocale } from '@/lib/i18n';
import { t } from '@/lib/translations';

interface Props {
  cards: DecisionEntryCardModel[];
  locale: BlogLocale;
}

const { cards, locale } = Astro.props;
const featured = cards.filter((card) => card.featuredPriority < 999).slice(0, 2);
const featuredIds = new Set(featured.map((card) => card.id));
const grid = cards.filter((card) => !featuredIds.has(card.id));
---

{cards.length === 0 ? (
  <div class="decision-empty-state section-block">
    <p>{t(locale, 'topic.noGuides')}</p>
  </div>
) : (
  <>
    {featured.length > 0 && (
      <section class="decision-featured-section section-block">
        <div class="section-head">
          <div>
            <h2>{t(locale, 'topic.topPicks')}</h2>
            <p>{t(locale, 'topic.topPicksDesc')}</p>
          </div>
        </div>
        <div class="decision-featured-grid-v2">
          {featured.map((card) => (
            <DecisionFeaturedCardStatic card={card} />
          ))}
        </div>
      </section>
    )}

    {grid.length > 0 && (
      <section class="decision-grid-section section-block">
        <div class="section-head">
          <div>
            <h2>{t(locale, 'topic.moreGuides')}</h2>
            <p>{t(locale, 'topic.moreGuidesDesc')}</p>
          </div>
        </div>
        <div class="decision-grid-v2">
          {grid.map((card) => (
            <DecisionGridCardStatic card={card} />
          ))}
        </div>
      </section>
    )}
  </>
)}
