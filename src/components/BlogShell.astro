---
import { blogBasePath, type BlogLocale, locales } from '@/lib/i18n';
import { t } from '@/lib/translations';
import { topics } from '@/lib/topics';
import LanguageSelector from './LanguageSelector.astro';

interface Props {
  locale: BlogLocale;
  localePaths?: Partial<Record<BlogLocale, string>>;
  /** When false, hides the duplicate blog title block (e.g. homepage uses DecisionHomeHub hero). */
  showBlogIntro?: boolean;
}

const { locale, localePaths, showBlogIntro = true } = Astro.props;
const siteUrl = 'https://www.gamegulf.com';
---

<div class="blog-page">
  <header class="site-header">
    <div class="blog-shell site-header-inner">
      <a href={siteUrl} class="brand-lockup">
        <img
          src="https://cdn.gamegulf.com/brand/logo.png"
          alt="GameGulf"
          class="brand-logo-img"
          width="140"
          height="32"
        />
      </a>
      <LanguageSelector locale={locale} localePaths={localePaths} />
    </div>
  </header>

  <main class="blog-shell">
    {showBlogIntro && (
      <section class="blog-intro">
        <div>
          <p class="eyebrow">GameGulf Blog</p>
          <h1 class="blog-intro-title">
            {t(locale, 'shell.blogTitle')}
          </h1>
          <p>{t(locale, 'shell.description')}</p>
        </div>
      </section>
    )}

    <nav class="topic-nav section-block" aria-label="Guides">
      <div class="topic-nav-row">
        {topics.map((tp) => (
          <a href={`${blogBasePath}/${locale}/guides/${tp.slug}`} class="topic-nav-chip">
            {tp.label[locale]}
          </a>
        ))}
      </div>
    </nav>

    <slot />

    <footer class="site-footer section-block">
      <div class="site-footer-grid">
        <div class="footer-brand-col">
          <a href={siteUrl} class="brand-lockup">
            <img
              src="https://cdn.gamegulf.com/brand/logo.png"
              alt="GameGulf"
              class="footer-logo-img"
              width="180"
              height="40"
            />
          </a>
          <div class="footer-social-row">
            <a href="https://www.facebook.com/profile.php?id=61575593784420" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="footer-social-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://www.instagram.com/game.gulf" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer-social-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="https://x.com/Game_Gulf_" target="_blank" rel="noopener noreferrer" aria-label="X" class="footer-social-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://www.tiktok.com/@gamegulf_" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="footer-social-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            </a>
            <a href="https://www.youtube.com/gamegulf" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="footer-social-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
            <a href="https://t.me/gamegulfs" target="_blank" rel="noopener noreferrer" aria-label="Telegram" class="footer-social-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0h-.056zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            </a>
            <a href="https://discord.gg/zB2fpgAaqB" target="_blank" rel="noopener noreferrer" aria-label="Discord" class="footer-social-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
            </a>
          </div>
        </div>
        <div class="footer-col">
          <h3>About</h3>
          <a href={`${siteUrl}/aboutus`}>About Us</a>
          <a href={`${siteUrl}/contactus`}>Contact Us</a>
          <a href={`${siteUrl}/files/tc`}>Terms &amp; Conditions</a>
        </div>
        <div class="footer-col">
          <h3>Legal Notice</h3>
          <a href={`${siteUrl}/files/legalnotice`}>Legal Notice</a>
          <a href={`${siteUrl}/files/cgv`}>CGV</a>
          <a href={`${siteUrl}/files/privacy`}>Privacy Notice</a>
        </div>
        <div class="footer-col">
          <h3>Customer Service</h3>
          <div class="footer-cs-card">
            <p>Response within <strong>12 Hours</strong></p>
            <span class="footer-cs-badge" aria-disabled="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M3 18v-6a9 9 0 0118 0v6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3v5zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3v5z" fill="currentColor"/>
              </svg>
              7 X 24H
            </span>
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <p class="footer-company">
          GameGulf is a product of Neon Tech Innovations Limited, a Hong Kong company, located at Rm D07, 8/F, Kai Tak Factory Building, No. 99 King Fuk Street, San Po Kong, Hong Kong.
        </p>
        <p class="footer-copyright">&copy; 2024–2026 GameGulf. All rights reserved.</p>
      </div>
    </footer>
  </main>
</div>
