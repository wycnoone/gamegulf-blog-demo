---
import type { DecisionEntryCardModel } from '@/lib/blog-shared';
import { getDecisionCardDisplay } from '@/lib/decision-card-display';

interface Props {
  card: DecisionEntryCardModel;
}

const { card } = Astro.props;

const display = getDecisionCardDisplay(card);
const primaryHref = card.href;
---

<article class="decision-featured-card-v2 decision-featured-card-pro">
  <a href={card.href} class="decision-card-link-overlay" aria-label={display.displayTitle}></a>
  <div class="decision-cover-pro decision-cover-pro-featured">
    {card.coverImage ? (
      <img src={card.coverImage} alt={card.gameTitle} class="decision-cover-image-pro" loading="lazy" />
    ) : (
      <div class="decision-cover-fallback-pro" aria-hidden="true"></div>
    )}
    <div class="decision-cover-accent-pro" aria-hidden="true"></div>
  </div>

  <div class="decision-featured-body decision-card-body-pro">
    <div class="decision-card-title-block-pro">
      <h3><a href={card.href}>{display.displayTitle}</a></h3>
    </div>

    <div class="decision-tag-row decision-tag-row-pro">
      {card.tags.slice(0, 2).map((tag) => (
        <span class="decision-tag decision-tag-pro">{tag}</span>
      ))}
    </div>

    <p class="decision-summary-pro decision-summary-block-pro">{display.compactWhatItIs}</p>

    {display.compactCommunityVibe && (
      <div class="decision-vibe-pro">
        <span class="decision-vibe-label-pro">{display.playerConsensusLabel}</span>
        <p class="decision-vibe-text-pro">&ldquo;{display.compactCommunityVibe}&rdquo;</p>
      </div>
    )}

    <div class="decision-stats-row-pro">
      <span class="decision-stat-item-pro">
        <svg class="decision-stat-svg-pro" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="8.25" stroke="currentColor" stroke-width="2.2" />
          <path d="M12 7.5V12.4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
          <path d="M12 12.4L15.2 14.2" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
        </svg>
        <span>{display.estimatedLengthLabel}{' '}<strong>{card.playtime || display.missingValueLabel}</strong></span>
      </span>
      {display.reviewMeta && (
        <span class="decision-stat-item-pro">
          <span class="decision-meta-icon-pro" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
              <path d="M4 16V8L12 13L20 8V16" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span>{display.reviewMeta}</span>
        </span>
      )}
    </div>

    <div class="decision-core-grid-pro">
      <div class="decision-core-item-pro">
        <span class="decision-core-label-pro">{display.bestForLabel}</span>
        <span class="decision-core-value-pro">{display.compactBestFor}</span>
      </div>
      <div class="decision-core-item-pro">
        <span class="decision-core-label-pro">{display.adviceLabel}</span>
        <span class="decision-core-value-pro decision-core-value-signal-pro">{display.priceAdviceText}</span>
        <span class="decision-core-support-pro">{display.priceAdviceDetail}</span>
      </div>
    </div>

    <div class="decision-cta-row decision-cta-row-pro">
      <a href={primaryHref} class="decision-cta-primary-pro">
        <svg class="decision-cta-plus-pro" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 4.5V15.5" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
          <path d="M4.5 10H15.5" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
        </svg>
        <span>{display.primaryCtaLabel}</span>
        <svg class="decision-cta-plus-pro" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 4.5V15.5" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
          <path d="M4.5 10H15.5" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
        </svg>
      </a>
      <a href={card.priceTrackHref} class="decision-cta-track-pro">{display.trackLabel}</a>
    </div>

    <div class="decision-card-footer-meta-pro">
      <span>{display.cardDate}</span>
      <span>{display.readingMeta}</span>
    </div>
  </div>
</article>
