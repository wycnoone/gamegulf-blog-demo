---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { blogBasePath, locales, localeLabels } from '@/lib/i18n';
import { t } from '@/lib/translations';
---

<BaseLayout title="GameGulf Blog" lang="en">
  <main class="landing-shell">
    <section class="landing-hero">
      <p class="eyebrow">GameGulf Blog</p>
      <h1>{t('en', 'landing.headline')}</h1>
      <p class="hero-copy">{t('en', 'landing.description')}</p>
      <div class="hero-actions">
        {locales.map((l) => (
          <a
            href={`${blogBasePath}/${l}`}
            class={l === 'en' ? '' : 'secondary-link'}
          >
            {t(l, 'landing.exploreGuides', { lang: localeLabels[l] })}
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
