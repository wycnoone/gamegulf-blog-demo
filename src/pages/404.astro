---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" lang="en">
  <main class="landing-shell">
    <section class="landing-hero" style="text-align: center;">
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p class="hero-copy">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="hero-actions" style="justify-content: center;">
        <a href={`${import.meta.env.BASE_URL}en`}>Browse English guides</a>
        <a href={`${import.meta.env.BASE_URL}zh-hans`} class="secondary-link">查看中文指南</a>
      </div>
    </section>
  </main>
</BaseLayout>
