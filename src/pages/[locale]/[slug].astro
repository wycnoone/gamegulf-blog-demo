---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogShell from '@/components/BlogShell.astro';
import FaqList from '@/components/FaqList.astro';
import {
  blogBasePath,
  formatDate,
  getAllBlogPaths,
  getAlternatePostPaths,
  getCategoryMeta,
  getLocaleAlternates,
  getOgImage,
  getPost,
  getRelatedPosts,
  getVerdictLabel,
  getArticleTitleQuestion,
  renderPost,
  siteUrl,
} from '@/lib/blog';
import { isLocale, locales, langTags, type BlogLocale } from '@/lib/i18n';
import { t } from '@/lib/translations';

export async function getStaticPaths() {
  const paths = await getAllBlogPaths();
  return paths.map((entry) => ({
    params: { locale: entry.locale, slug: entry.slug },
  }));
}

const { locale, slug } = Astro.params;

if (!isLocale(locale)) {
  return Astro.redirect(`${blogBasePath}/404`);
}

const typedLocale = locale as BlogLocale;
const post = await getPost(typedLocale, slug);

if (!post) {
  return Astro.redirect(`${blogBasePath}/404`);
}

const Content = await renderPost(post);
const relatedPosts = await getRelatedPosts(post);
const alternatePostPaths = await getAlternatePostPaths(post);
const path = `${blogBasePath}/${typedLocale}/${slug}`;
const ogImage = getOgImage(post);

const localePaths: Partial<Record<BlogLocale, string>> = { [typedLocale]: path, ...alternatePostPaths };
const alternates = getLocaleAlternates(localePaths);
const displayPlatformLabel = post.primaryPlatformLabel || post.platform;
const otherPlatformLabels = post.otherPlatformLabels || [];
const showOtherVersionsBlock = post.hasOtherPlatforms && otherPlatformLabels.length > 0;
const comparePricingLabel = post.hasOtherPlatforms
  ? t(typedLocale, 'article.viewAllPlatformPricing')
  : t(typedLocale, 'article.comparePricing');
const comparePricingCardTitle = post.hasOtherPlatforms
  ? t(typedLocale, 'article.viewAllPlatformPricing')
  : t(typedLocale, 'article.compareLivePricing');
const comparePricingCardDesc = post.hasOtherPlatforms
  ? t(typedLocale, 'article.viewAllPlatformPricingDesc', { gameTitle: post.gameTitle })
  : t(typedLocale, 'article.compareLivePricingDesc', { gameTitle: post.gameTitle });

const verdictText = post.verdict
  ? getVerdictLabel(post.verdict, typedLocale)
  : t(typedLocale, 'article.seeFullAnalysis');

const shortTitle = `${post.gameTitle}: ${verdictText} | GameGulf`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'GameGulf', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: t(typedLocale, 'shell.blogTitle'), item: `${siteUrl}${blogBasePath}/${typedLocale}` },
    { '@type': 'ListItem', position: 3, name: post.gameTitle, item: `${siteUrl}${path}` },
  ],
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: post.faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.description,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  author: { '@type': 'Person', name: post.author },
  publisher: {
    '@type': 'Organization',
    name: 'GameGulf',
    url: siteUrl,
  },
  about: {
    '@type': 'VideoGame',
    name: post.gameTitle,
    gamePlatform: displayPlatformLabel,
    url: post.gameHref,
  },
  inLanguage: langTags[typedLocale],
  mainEntityOfPage: `${siteUrl}${path}`,
};

const verdictToRating: Record<string, number> = {
  buy_now: 9,
  right_player: 7,
  wait_for_sale: 6,
  not_best_fit: 4,
};
const reviewSchema = post.verdict ? {
  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: {
    '@type': 'VideoGame',
    name: post.gameTitle,
    gamePlatform: displayPlatformLabel,
    url: post.gameHref,
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: verdictToRating[post.verdict] ?? 7,
    bestRating: 10,
    worstRating: 1,
  },
  name: post.title,
  reviewBody: post.takeaway || post.decision,
  author: { '@type': 'Organization', name: 'GameGulf' },
  publisher: { '@type': 'Organization', name: 'GameGulf', url: siteUrl },
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  inLanguage: langTags[typedLocale],
  ...(post.bestFor ? {
    positiveNotes: {
      '@type': 'ItemList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: post.bestFor },
        ...(post.consensusPraise ? [{ '@type': 'ListItem', position: 2, name: post.consensusPraise }] : []),
      ],
    },
  } : {}),
  ...(post.avoidIf ? {
    negativeNotes: {
      '@type': 'ItemList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: post.avoidIf },
        ...(post.mainFriction ? [{ '@type': 'ListItem', position: 2, name: post.mainFriction }] : []),
      ],
    },
  } : {}),
} : null;

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: post.title,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.tldr-answer', '.takeaway-callout'],
  },
};

const priceCallText = post.priceCall
  ? { buy: t(typedLocale, 'article.priceCallBuy'), wait: t(typedLocale, 'article.priceCallWait'), watch: t(typedLocale, 'article.priceCallWatch') }[post.priceCall]
  : t(typedLocale, 'article.seeAnalysis');

const voices = post.playerVoices ?? [];
const positiveVoices = voices.filter((v) => v.sentiment === 'positive');
const memes = post.communityMemes ?? [];

const overviewWhatItIs = post.whatItIs;
const overviewPraise = post.consensusPraise;
const hasOverview = overviewWhatItIs || overviewPraise;

const articleTitleQuestion = getArticleTitleQuestion(typedLocale, post.title, post.gameTitle);
---

<BaseLayout
  title={shortTitle}
  description={post.description}
  lang={langTags[typedLocale]}
  canonical={path}
  ogImage={ogImage}
  ogType="article"
  alternates={alternates}
  jsonLd={[articleSchema, breadcrumbSchema, faqSchema, ...(reviewSchema ? [reviewSchema] : []), speakableSchema]}
  publishedTime={post.publishedAt}
  modifiedTime={post.updatedAt || post.publishedAt}
  articleSection={getCategoryMeta(typedLocale, post.category).title}
  articleTags={post.tags.slice(0, 5)}
>
  <BlogShell locale={typedLocale} localePaths={localePaths}>
    <section class="article-shell section-block">
      <div>
        <nav class="article-breadcrumb" aria-label="Breadcrumb">
          <a href={siteUrl}>GameGulf</a>
          <span class="bc-sep">›</span>
          <a href={`${blogBasePath}/${typedLocale}`}>{t(typedLocale, 'shell.blogTitle')}</a>
          <span class="bc-sep">›</span>
          <span class="bc-current">{post.gameTitle}</span>
        </nav>
        <header class="article-header">
          <div class="article-summary-card article-summary-card-compact">
            <div
              class="article-cover-strip"
              style={post.coverImage
                ? `background-image: linear-gradient(180deg, rgba(14, 20, 40, 0.15), rgba(14, 20, 40, 0.55)), url(${post.coverImage})`
                : undefined}
            >
              <div></div>
              <div class="article-cover-strip-meta">
                <span>{post.heroStat}</span>
              </div>
            </div>

            <h1 class="article-title-split">
              <span class="article-title-game">{post.gameTitle}</span>
              <span class="article-title-question">{articleTitleQuestion}</span>
            </h1>

            <div class="meta-row">
              <span>{formatDate(post.updatedAt || post.publishedAt, typedLocale)}</span>
              {post.updatedAt && post.updatedAt !== post.publishedAt && (
                <span class="meta-updated">{t(typedLocale, 'article.updated', { date: formatDate(post.updatedAt, typedLocale) })}</span>
              )}
              <span>{post.readingTime}</span>
            </div>

            {post.tldr && (
              <div class="tldr-answer" data-nosnippet="false">
                <strong class="tldr-label">{t(typedLocale, 'article.tldr')}</strong>
                <p>{post.tldr}</p>
              </div>
            )}

            <div class="decision-snapshot">
              <div class="decision-snapshot-row">
                <div class="decision-snapshot-item">
                  <span class="decision-snapshot-label">{t(typedLocale, 'article.verdictLabel')}</span>
                  <strong class="decision-snapshot-value verdict-value">{verdictText}</strong>
                </div>
                <div class="decision-snapshot-item">
                  <span class="decision-snapshot-label">{t(typedLocale, 'article.primaryPlatform')}</span>
                  <span class="decision-snapshot-value">{displayPlatformLabel}</span>
                </div>
                {post.playtime && (
                  <div class="decision-snapshot-item">
                    <span class="decision-snapshot-label">{t(typedLocale, 'article.playtime')}</span>
                    <span class="decision-snapshot-value">{post.playtime}</span>
                  </div>
                )}
              </div>
              <div class="decision-snapshot-row">
                <div class="decision-snapshot-item decision-snapshot-item-wide">
                  <span class="decision-snapshot-label">{t(typedLocale, 'article.bestFor')}</span>
                  <span class="decision-snapshot-value">{post.bestFor || post.fitLabel || post.decision}</span>
                </div>
              </div>
            </div>

            <p class="decision-snapshot-signal">{post.priceSignal}</p>
          </div>
        </header>

        {hasOverview && (
          <section class="game-overview">
            {overviewWhatItIs && (
              <div class="overview-row">
                <strong class="overview-label">{t(typedLocale, 'article.whatItIs')}</strong>
                <p>{overviewWhatItIs}</p>
              </div>
            )}
            {overviewPraise && (
              <div class="overview-row overview-positive">
                <strong class="overview-label">{t(typedLocale, 'article.whyPlayersLoveIt')}</strong>
                <p>{overviewPraise}</p>
              </div>
            )}
          </section>
        )}

        {showOtherVersionsBlock && (
          <section class="platform-versions-note section-block">
            <div class="platform-versions-note-content">
              <div class="platform-versions-note-line">
                <strong class="platform-versions-note-title">{t(typedLocale, 'article.otherVersionsInlineLink')}</strong>
                <div class="platform-versions-chip-row">
                  {otherPlatformLabels.map((label) => (
                    <span class="platform-versions-chip">{label}</span>
                  ))}
                </div>
              </div>
            </div>
            <a href={post.gameHref} class="button-link secondary platform-versions-note-action">{comparePricingLabel}</a>
          </section>
        )}

        <div class="article-mobile-actions">
          <section class="sidebar-card sidebar-card-cta">
            <h3>{t(typedLocale, 'article.nextSteps')}</h3>
            <div class="cta-row">
              <a href={post.gameHref} class="button-link">{comparePricingLabel}</a>
              <a href={post.priceTrackHref} class="button-link accent">{t(typedLocale, 'article.setPriceAlert')}</a>
              <a href={post.wishlistHref} class="button-link secondary">{t(typedLocale, 'article.saveToWishlist')}</a>
            </div>
          </section>
        </div>

        <section class="article-reading-card">
          <article class="article-body">
            <Content />
          </article>
        </section>

        {post.takeaway && (
          <div class="takeaway-callout">
            <strong class="takeaway-label">{t(typedLocale, 'article.bottomLine')}</strong>
            <p>{post.takeaway}</p>
          </div>
        )}

        {positiveVoices.length > 0 && (
          <section class="player-voices section-block">
            <h2>{t(typedLocale, 'article.whatPlayersSaying')}</h2>
            <ul class="voices-list">
              {positiveVoices.map((v) => (
                <li class="voice-item">
                  <span class="voice-icon">👍</span>
                  <span>{v.quote}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        {memes.length > 0 && (
          <section class="community-memes section-block">
            <h2>{t(typedLocale, 'article.communityCulture')}</h2>
            <p class="memes-intro">{t(typedLocale, 'article.memesIntro', { gameTitle: post.gameTitle })}</p>
            <ul class="memes-list">
              {memes.map((m) => (
                <li class="meme-item">{m}</li>
              ))}
            </ul>
          </section>
        )}

        <section class="gamegulf-recommends section-block">
          <h2>{t(typedLocale, 'article.whatToDoNext')}</h2>
          <div class="recommends-grid">
            <a href={post.gameHref} class="recommends-card">
              <strong>{comparePricingCardTitle}</strong>
              <span>{comparePricingCardDesc}</span>
            </a>
            <a href={post.priceTrackHref} class="recommends-card">
              <strong>{t(typedLocale, 'article.setAPriceAlert')}</strong>
              <span>{t(typedLocale, 'article.setPriceAlertDesc')}</span>
            </a>
            <a href={post.wishlistHref} class="recommends-card">
              <strong>{t(typedLocale, 'article.addToWishlist')}</strong>
              <span>{t(typedLocale, 'article.addToWishlistDesc')}</span>
            </a>
          </div>
        </section>

        <section class="section-block">
          <div class="section-head">
            <div>
              <h2>FAQ</h2>
              <p>{t(typedLocale, 'article.faqIntro')}</p>
            </div>
          </div>
          <FaqList items={post.faq} />
        </section>
      </div>

      <aside class="sidebar-stack">
        <section class="sidebar-card sidebar-card-cta">
          <h3>{t(typedLocale, 'article.nextSteps')}</h3>
          <div class="cta-row">
            <a href={post.gameHref} class="button-link">{comparePricingLabel}</a>
            <a href={post.priceTrackHref} class="button-link accent">{t(typedLocale, 'article.setPriceAlert')}</a>
            <a href={post.wishlistHref} class="button-link secondary">{t(typedLocale, 'article.saveToWishlist')}</a>
            <a href={post.membershipHref} class="button-link secondary">{t(typedLocale, 'article.seeTrialBenefits')}</a>
          </div>
        </section>
        <section class="sidebar-card sidebar-card-emphasis">
          <h3>{t(typedLocale, 'article.gameAtAGlance')}</h3>
          <dl class="glance-list">
            <div class="glance-row">
              <dt>{t(typedLocale, 'article.primaryPlatform')}</dt>
              <dd>{displayPlatformLabel}</dd>
            </div>
            {post.playStyle && (
              <div class="glance-row">
                <dt>{t(typedLocale, 'article.playStyle')}</dt>
                <dd>{post.playStyle}</dd>
              </div>
            )}
            {post.playtime && (
              <div class="glance-row">
                <dt>{t(typedLocale, 'article.playtime')}</dt>
                <dd>{post.playtime}</dd>
              </div>
            )}
            {post.communityVibe && (
              <div class="glance-row">
                <dt>{t(typedLocale, 'article.playerConsensus')}</dt>
                <dd>{post.communityVibe}</dd>
              </div>
            )}
            <div class="glance-row">
              <dt>{t(typedLocale, 'article.priceCallLabel')}</dt>
              <dd><strong>{priceCallText}</strong></dd>
            </div>
          </dl>
        </section>
        <section class="sidebar-card">
          <h3>{t(typedLocale, 'article.relatedDecisions')}</h3>
          <ul>
            {relatedPosts.map((item) => (
              <li class="related-item">
                <a class="inline-link" href={`${blogBasePath}/${item.locale}/${item.slug}`}>
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      </aside>
    </section>
  </BlogShell>
</BaseLayout>
