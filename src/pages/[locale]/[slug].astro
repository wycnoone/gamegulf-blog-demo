---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogShell from '@/components/BlogShell.astro';
import FaqList from '@/components/FaqList.astro';
import {
  blogBasePath,
  formatDate,
  getAllBlogPaths,
  getAlternatePostPath,
  getLocaleAlternates,
  getOgImage,
  getPost,
  getRelatedPosts,
  getVerdictLabel,
  renderPost,
  siteUrl,
} from '@/lib/blog';
import { isLocale, locales, type BlogLocale } from '@/lib/i18n';

export async function getStaticPaths() {
  const paths = await getAllBlogPaths();
  return paths.map((entry) => ({
    params: { locale: entry.locale, slug: entry.slug },
  }));
}

const { locale, slug } = Astro.params;

if (!isLocale(locale)) {
  return Astro.redirect(`${blogBasePath}/404`);
}

const typedLocale = locale as BlogLocale;
const post = await getPost(typedLocale, slug);

if (!post) {
  return Astro.redirect(`${blogBasePath}/404`);
}

const Content = await renderPost(post);
const relatedPosts = await getRelatedPosts(post);
const alternatePostPath = await getAlternatePostPath(post);
const path = `${blogBasePath}/${typedLocale}/${slug}`;
const ogImage = getOgImage(post);

const languages: Record<string, string> = { [typedLocale]: path };
if (alternatePostPath) {
  const otherLocale = locales.find((l) => l !== typedLocale);
  if (otherLocale) languages[otherLocale] = alternatePostPath;
}
const alternates = getLocaleAlternates(languages);

const verdictText = post.verdict
  ? getVerdictLabel(post.verdict, typedLocale)
  : (typedLocale === 'en' ? 'See full analysis' : '查看完整分析');

const shortTitle = `${post.gameTitle}: ${verdictText} | GameGulf`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: `${siteUrl}${blogBasePath}/${typedLocale}` },
    { '@type': 'ListItem', position: 2, name: post.gameTitle, item: `${siteUrl}${path}` },
  ],
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: post.faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.description,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  author: { '@type': 'Person', name: post.author },
  publisher: {
    '@type': 'Organization',
    name: 'GameGulf',
    url: siteUrl,
  },
  about: {
    '@type': 'VideoGame',
    name: post.gameTitle,
    gamePlatform: post.platform,
  },
  inLanguage: typedLocale,
  mainEntityOfPage: `${siteUrl}${path}`,
};

const priceCallLabels: Record<string, Record<BlogLocale, string>> = {
  buy: { en: 'Buy now', 'zh-hans': '现在买' },
  wait: { en: 'Wait for sale', 'zh-hans': '等打折' },
  watch: { en: 'Watch & track', 'zh-hans': '关注追踪' },
};
const priceCallText = post.priceCall
  ? priceCallLabels[post.priceCall]?.[typedLocale] ?? post.priceCall
  : (typedLocale === 'en' ? 'See analysis' : '查看分析');

const voices = post.playerVoices ?? [];
const positiveVoices = voices.filter((v) => v.sentiment === 'positive');
const memes = post.communityMemes ?? [];

const overviewWhatItIs = post.whatItIs;
const overviewPraise = post.consensusPraise;
const hasOverview = overviewWhatItIs || overviewPraise;
---

<BaseLayout
  title={shortTitle}
  description={post.description}
  lang={typedLocale === 'zh-hans' ? 'zh-Hans' : 'en'}
  canonical={path}
  ogImage={ogImage}
  ogType="article"
  alternates={alternates}
  jsonLd={[articleSchema, breadcrumbSchema, faqSchema]}
>
  <BlogShell locale={typedLocale}>
    <section class="article-shell section-block">
      <div>
        <header class="article-header">
          <div class="article-summary-card article-summary-card-compact">
            <div
              class="article-cover-strip"
              style={post.coverImage
                ? `background-image: linear-gradient(180deg, rgba(14, 20, 40, 0.15), rgba(14, 20, 40, 0.55)), url(${post.coverImage})`
                : undefined}
            >
              <div></div>
              <div class="article-cover-strip-meta">
                <span>{post.heroStat}</span>
              </div>
            </div>

            <h1 class="article-title-split">
              <span class="article-title-game">{post.gameTitle}</span>
              <span class="article-title-question">
                {typedLocale === 'en'
                  ? post.title.replace(post.gameTitle, '').replace(/^[\s:—–-]+/, '')
                  : post.title.replace(post.gameTitle, '').replace(/^[\s：:—–\-《》「」]+/, '')}
              </span>
            </h1>

            <div class="meta-row">
              <span>{formatDate(post.publishedAt, post.locale)}</span>
              <span>{post.readingTime}</span>
            </div>

            {/* ── Decision Snapshot ── */}
            <div class="decision-snapshot">
              <div class="decision-snapshot-row">
                <div class="decision-snapshot-item">
                  <span class="decision-snapshot-label">
                    {typedLocale === 'en' ? 'GameGulf Verdict' : 'GameGulf 购买意见'}
                  </span>
                  <strong class="decision-snapshot-value verdict-value">{verdictText}</strong>
                </div>
                {post.playtime && (
                  <div class="decision-snapshot-item">
                    <span class="decision-snapshot-label">
                      {typedLocale === 'en' ? 'Playtime' : '游玩时长'}
                    </span>
                    <span class="decision-snapshot-value">{post.playtime}</span>
                  </div>
                )}
              </div>
              <div class="decision-snapshot-row">
                <div class="decision-snapshot-item decision-snapshot-item-wide">
                  <span class="decision-snapshot-label">
                    {typedLocale === 'en' ? 'Best For' : '最适合'}
                  </span>
                  <span class="decision-snapshot-value">{post.bestFor || post.fitLabel || post.decision}</span>
                </div>
              </div>
            </div>

            <p class="decision-snapshot-signal">{post.priceSignal}</p>
          </div>
        </header>

        {/* ── Game Overview — 10-second scan layer ── */}
        {hasOverview && (
          <section class="game-overview">
            {overviewWhatItIs && (
              <div class="overview-row">
                <strong class="overview-label">
                  {typedLocale === 'en' ? 'What it is' : '这是什么游戏'}
                </strong>
                <p>{overviewWhatItIs}</p>
              </div>
            )}
            {overviewPraise && (
              <div class="overview-row overview-positive">
                <strong class="overview-label">
                  {typedLocale === 'en' ? 'Why players love it' : '玩家最喜欢'}
                </strong>
                <p>{overviewPraise}</p>
              </div>
            )}
          </section>
        )}

        <div class="article-mobile-actions">
          <section class="sidebar-card sidebar-card-cta">
            <h3>{typedLocale === 'en' ? 'Next steps on GameGulf' : 'GameGulf 下一步'}</h3>
            <div class="cta-row">
              <a href={post.gameHref} class="button-link">{typedLocale === 'en' ? 'Compare pricing' : '比较价格'}</a>
              <a href={post.priceTrackHref} class="button-link accent">{typedLocale === 'en' ? 'Set price alert' : '开启降价提醒'}</a>
              <a href={post.wishlistHref} class="button-link secondary">{typedLocale === 'en' ? 'Save to wishlist' : '加入愿望单'}</a>
            </div>
          </section>
        </div>

        {/* ── Full analysis ── */}
        <section class="article-reading-card">
          <article class="article-body">
            <Content />
          </article>
        </section>

        {/* ── Takeaway callout ── */}
        {post.takeaway && (
          <div class="takeaway-callout">
            <strong class="takeaway-label">
              {typedLocale === 'en' ? 'Bottom line' : '一句话结论'}
            </strong>
            <p>{post.takeaway}</p>
          </div>
        )}

        {/* ── Player voices (positive only) ── */}
        {positiveVoices.length > 0 && (
          <section class="player-voices section-block">
            <h2>{typedLocale === 'en' ? 'What players are saying' : '玩家怎么说'}</h2>
            <ul class="voices-list">
              {positiveVoices.map((v) => (
                <li class="voice-item">
                  <span class="voice-icon">👍</span>
                  <span>{v.quote}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        {/* ── Community memes ── */}
        {memes.length > 0 && (
          <section class="community-memes section-block">
            <h2>{typedLocale === 'en' ? 'Community culture' : '社区梗 & 玩家文化'}</h2>
            <p class="memes-intro">
              {typedLocale === 'en'
                ? `Inside jokes and references you will probably encounter once you start playing ${post.gameTitle}.`
                : `玩了${post.gameTitle}之后你大概率会碰到的社区梗和玩家黑话。`}
            </p>
            <ul class="memes-list">
              {memes.map((m) => (
                <li class="meme-item">{m}</li>
              ))}
            </ul>
          </section>
        )}

        {/* ── GameGulf Recommends ── */}
        <section class="gamegulf-recommends section-block">
          <h2>{typedLocale === 'en' ? 'What to do next on GameGulf' : '在 GameGulf 上的下一步'}</h2>
          <div class="recommends-grid">
            <a href={post.gameHref} class="recommends-card">
              <strong>{typedLocale === 'en' ? 'Compare live pricing' : '比较实时价格'}</strong>
              <span>{typedLocale === 'en'
                ? `See current prices for ${post.gameTitle} across regions.`
                : `查看${post.gameTitle}各区域的当前价格。`}</span>
            </a>
            <a href={post.priceTrackHref} class="recommends-card">
              <strong>{typedLocale === 'en' ? 'Set a price alert' : '设置降价提醒'}</strong>
              <span>{typedLocale === 'en'
                ? 'Get notified when the price drops to your target.'
                : '价格降到目标时自动通知你。'}</span>
            </a>
            <a href={post.wishlistHref} class="recommends-card">
              <strong>{typedLocale === 'en' ? 'Add to wishlist' : '加入愿望单'}</strong>
              <span>{typedLocale === 'en'
                ? 'Save it and decide later with full price context.'
                : '先收藏，之后结合价格走势再决定。'}</span>
            </a>
          </div>
        </section>

        <section class="section-block">
          <div class="section-head">
            <div>
              <h2>FAQ</h2>
              <p>
                {typedLocale === 'en'
                  ? 'Quick answers to the questions players usually ask before buying.'
                  : '购买前最常见的问题，方便你快速判断。'}
              </p>
            </div>
          </div>
          <FaqList items={post.faq} />
        </section>
      </div>

      <aside class="sidebar-stack">
        <section class="sidebar-card sidebar-card-cta">
          <h3>{typedLocale === 'en' ? 'Next steps on GameGulf' : 'GameGulf 下一步'}</h3>
          <div class="cta-row">
            <a href={post.gameHref} class="button-link">{typedLocale === 'en' ? 'Compare pricing' : '比较价格'}</a>
            <a href={post.priceTrackHref} class="button-link accent">{typedLocale === 'en' ? 'Set price alert' : '开启降价提醒'}</a>
            <a href={post.wishlistHref} class="button-link secondary">{typedLocale === 'en' ? 'Save to wishlist' : '加入愿望单'}</a>
            <a href={post.membershipHref} class="button-link secondary">{typedLocale === 'en' ? 'See trial benefits' : '查看试玩权益'}</a>
          </div>
        </section>
        <section class="sidebar-card sidebar-card-emphasis">
          <h3>{typedLocale === 'en' ? 'Game at a Glance' : '游戏速览'}</h3>
          <dl class="glance-list">
            <div class="glance-row">
              <dt>{typedLocale === 'en' ? 'Platform' : '平台'}</dt>
              <dd>{post.platform}</dd>
            </div>
            {post.playStyle && (
              <div class="glance-row">
                <dt>{typedLocale === 'en' ? 'Play Style' : '玩法类型'}</dt>
                <dd>{post.playStyle}</dd>
              </div>
            )}
            {post.playtime && (
              <div class="glance-row">
                <dt>{typedLocale === 'en' ? 'Playtime' : '游玩时长'}</dt>
                <dd>{post.playtime}</dd>
              </div>
            )}
            {post.communityVibe && (
              <div class="glance-row">
                <dt>{typedLocale === 'en' ? 'Player Consensus' : '玩家共识'}</dt>
                <dd>{post.communityVibe}</dd>
              </div>
            )}
            <div class="glance-row">
              <dt>{typedLocale === 'en' ? 'Price Call' : '价格建议'}</dt>
              <dd><strong>{priceCallText}</strong></dd>
            </div>
          </dl>
        </section>
        <section class="sidebar-card">
          <h3>{typedLocale === 'en' ? 'Related decisions' : '相关判断'}</h3>
          <ul>
            {relatedPosts.map((item) => (
              <li class="related-item">
                <a class="inline-link" href={`${blogBasePath}/${item.locale}/${item.slug}`}>
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      </aside>
    </section>
  </BlogShell>
</BaseLayout>
