---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogShell from '@/components/BlogShell.astro';
import DecisionFeaturedCardStatic from '@/components/DecisionFeaturedCardStatic.astro';
import DecisionGridCardStatic from '@/components/DecisionGridCardStatic.astro';
import {
  blogBasePath,
  defaultOgImage,
  getDecisionEntryCards,
  getLocaleAlternates,
} from '@/lib/blog';
import { isLocale, locales, langTags, type BlogLocale } from '@/lib/i18n';
import { t } from '@/lib/translations';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;

if (!isLocale(locale)) {
  return Astro.redirect(`${blogBasePath}/404`);
}

const typedLocale = locale as BlogLocale;
const cards = await getDecisionEntryCards(typedLocale);

const siteUrl = 'https://www.gamegulf.com';
const path = `${blogBasePath}/${typedLocale}`;
const localePaths = Object.fromEntries(locales.map((l) => [l, `${blogBasePath}/${l}`])) as Record<BlogLocale, string>;
const alternates = getLocaleAlternates(localePaths);

const listingTitle = t(typedLocale, 'listing.title');
const listingDescription = t(typedLocale, 'listing.description');
const featuredCards = cards.slice(0, Math.min(2, cards.length));
const latestCards = cards.slice(featuredCards.length);

const jsonLd: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: listingTitle,
    description: listingDescription,
    url: `${siteUrl}${path}`,
    inLanguage: langTags[typedLocale],
    isPartOf: {
      '@type': 'WebSite',
      name: 'GameGulf',
      url: siteUrl,
    },
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: cards.length,
      itemListElement: cards.slice(0, 10).map((card, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${siteUrl}${card.href}`,
        name: card.title,
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'GameGulf',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: listingTitle,
        item: `${siteUrl}${path}`,
      },
    ],
  },
];
---

<BaseLayout
  title={listingTitle}
  description={listingDescription}
  lang={langTags[typedLocale]}
  canonical={path}
  ogImage={defaultOgImage}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <BlogShell locale={typedLocale} localePaths={localePaths}>
    {cards.length > 0 && (
      <section class="decision-featured-section section-block">
        <div class="section-head">
          <div>
            <h2>{t(typedLocale, 'home.section.all.featured')}</h2>
            <p>{t(typedLocale, 'home.section.all.featuredDesc')}</p>
          </div>
        </div>
        <div class="decision-featured-grid-v2">
          {featuredCards.map((card) => (
            <DecisionFeaturedCardStatic card={card} />
          ))}
        </div>
      </section>
    )}

    {latestCards.length > 0 && (
      <section class="decision-latest-section section-block">
        <div class="section-head">
          <div>
            <h2>{t(typedLocale, 'home.section.all.latest')}</h2>
          </div>
        </div>
        <div class="decision-grid-v2">
          {latestCards.map((card) => (
            <DecisionGridCardStatic card={card} />
          ))}
        </div>
      </section>
    )}
  </BlogShell>
</BaseLayout>
