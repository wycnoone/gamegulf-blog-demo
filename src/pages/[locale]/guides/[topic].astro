---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogShell from '@/components/BlogShell.astro';
import TopicCardGridStatic from '@/components/TopicCardGridStatic.astro';
import {
  blogBasePath,
  defaultOgImage,
  getDecisionEntryCardsByTopic,
  getLocaleAlternates,
  siteUrl,
} from '@/lib/blog';
import { isLocale, locales, langTags, type BlogLocale } from '@/lib/i18n';
import { t } from '@/lib/translations';
import { topics, type TopicDefinition } from '@/lib/topics';

export async function getStaticPaths() {
  const paths: { params: { locale: string; topic: string }; props: { topic: TopicDefinition } }[] = [];

  for (const locale of locales) {
    for (const topic of topics) {
      const cards = await getDecisionEntryCardsByTopic(locale, topic.filter);
      if (cards.length > 0) {
        paths.push({
          params: { locale, topic: topic.slug },
          props: { topic },
        });
      }
    }
  }

  return paths;
}

const { locale, topic: topicSlug } = Astro.params;
const { topic } = Astro.props;

if (!isLocale(locale)) {
  return Astro.redirect(`${blogBasePath}/404`);
}

const typedLocale = locale as BlogLocale;
const cards = await getDecisionEntryCardsByTopic(typedLocale, topic.filter);
const path = `${blogBasePath}/${typedLocale}/guides/${topic.slug}`;

const localePaths = Object.fromEntries(
  locales.map((l) => [l, `${blogBasePath}/${l}/guides/${topic.slug}`]),
) as Record<BlogLocale, string>;
const alternates = getLocaleAlternates(localePaths);

const otherTopics = topics.filter((tp) => tp.slug !== topic.slug);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'GameGulf', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: t(typedLocale, 'shell.blogTitle'), item: `${siteUrl}${blogBasePath}/${typedLocale}` },
    { '@type': 'ListItem', position: 3, name: topic.title[typedLocale], item: `${siteUrl}${path}` },
  ],
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: topic.title[typedLocale],
  description: topic.description[typedLocale],
  url: `${siteUrl}${path}`,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: cards.length,
    itemListElement: cards.map((card, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: card.title,
      url: `${siteUrl}${card.href}`,
    })),
  },
};
---

<BaseLayout
  title={topic.title[typedLocale]}
  description={topic.description[typedLocale]}
  lang={langTags[typedLocale]}
  canonical={path}
  ogImage={defaultOgImage}
  alternates={alternates}
  jsonLd={[collectionSchema, breadcrumbSchema]}
>
  <BlogShell locale={typedLocale} localePaths={localePaths}>
    <section class="topic-page section-block">
      <nav class="article-breadcrumb" aria-label="Breadcrumb">
        <a href={siteUrl}>GameGulf</a>
        <span class="bc-sep">›</span>
        <a href={`${blogBasePath}/${typedLocale}`}>{t(typedLocale, 'shell.blogTitle')}</a>
        <span class="bc-sep">›</span>
        <span class="bc-current">{topic.label[typedLocale]}</span>
      </nav>
      <header class="decision-category-hero section-block">
        <p class="eyebrow">{t(typedLocale, 'guide.eyebrow')}</p>
        <h1>{topic.title[typedLocale]}</h1>
        <p class="worth-it-hero-copy">{topic.intro[typedLocale]}</p>
      </header>

      <TopicCardGridStatic cards={cards} locale={typedLocale} />

      {otherTopics.length > 0 && (
        <section class="section-block topic-related-section">
          <div class="section-head">
            <div>
              <h2>{t(typedLocale, 'guide.browseMore')}</h2>
              <p>{t(typedLocale, 'guide.browseMoreDesc')}</p>
            </div>
          </div>
          <div class="topic-link-grid">
            {otherTopics.map((tp) => (
              <a href={`${blogBasePath}/${typedLocale}/guides/${tp.slug}`} class="topic-link-card">
                <strong>{tp.label[typedLocale]}</strong>
                <span>{tp.description[typedLocale].slice(0, 60)}…</span>
              </a>
            ))}
          </div>
        </section>
      )}
    </section>
  </BlogShell>
</BaseLayout>
